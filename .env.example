# === Proveedor Open Banking ===
# "enablebanking" -> Enable Banking: AIS self-serve y gratis para uso personal,
#                    CaixaBank y casi toda la banca europea. RECOMENDADO en 2026.
# "gocardless"    -> GoCardless Bank Account Data (antes Nordigen). Nuevos registros CERRADOS.
# "truelayer"     -> UK/EU; la Data API (lectura) ya no es self-serve para cuentas nuevas.
FINMCP_PROVIDER=enablebanking

# === Enable Banking (si FINMCP_PROVIDER=enablebanking) ===
# Registra una app en https://enablebanking.com (Control Panel) y descarga la clave privada.
ENABLEBANKING_APP_ID=
# Ruta al .pem de tu clave privada. Por defecto: data/enablebanking_private.pem
# ENABLEBANKING_KEY_PATH=/ruta/absoluta/a/enablebanking_private.pem
# Nombre EXACTO del banco (lista con: finmcp institutions). Para CaixaBank suele ser "CaixaBank".
ENABLEBANKING_ASPSP_NAME=
ENABLEBANKING_COUNTRY=ES
# Enable Banking exige HTTPS. Regístrala igual en "Allowed redirect URLs" de tu app.
ENABLEBANKING_REDIRECT_URI=https://localhost:3000/callback

# === GoCardless Bank Account Data (si FINMCP_PROVIDER=gocardless) ===
# OJO: GoCardless ha cerrado los nuevos registros de Bank Account Data.
GOCARDLESS_SECRET_ID=
GOCARDLESS_SECRET_KEY=
GOCARDLESS_INSTITUTION_ID=
GOCARDLESS_COUNTRY=es
GOCARDLESS_REDIRECT_URI=http://localhost:3000/callback

# === TrueLayer (si FINMCP_PROVIDER=truelayer) ===
# Entorno: "sandbox" (datos mock) o "live" (tu banco real, requiere acceso live aprobado)
TRUELAYER_ENV=sandbox
TRUELAYER_CLIENT_ID=sandbox-yourapp-xxxxxx
TRUELAYER_CLIENT_SECRET=
TRUELAYER_REDIRECT_URI=http://localhost:3000/callback

# Proveedores (bancos) que se muestran en el diálogo de consentimiento.
# TrueLayer cubre cientos de bancos de UK y Europa; elige el tuyo en la consola.
#   sandbox -> Mock Bank:            uk-cs-mock
#   live (todos los de un país) ->   es-ob-all  ·  uk-ob-all  ·  fr-ob-all ...
#   live (banco concreto) ->         es-ob-bbva ·  es-ob-santander ·  es-ob-caixabank ...
# Consulta los IDs exactos en console.truelayer.com (Data API > Providers).
TRUELAYER_PROVIDERS=uk-cs-mock

# === Almacenamiento ===
# Por defecto: SQLite en <repo>/data/finmcp.db. Descomenta para cambiar la ruta.
# FINMCP_DB_PATH=/ruta/absoluta/a/openbanking-mcp/data/finmcp.db

# === Cifrado de tokens en reposo ===
# Clave Fernet. Si la dejas vacía, se genera una y se guarda en data/fernet.key (chmod 600).
# Generar una manualmente:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FINMCP_ENCRYPTION_KEY=

# Puerto del callback local del flujo OAuth (debe coincidir con la redirect URI)
FINMCP_CALLBACK_PORT=3000
