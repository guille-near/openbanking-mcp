# === TrueLayer ===
# Entorno: "sandbox" (datos mock) o "live" (tu banco real, requiere acceso live aprobado)
TRUELAYER_ENV=sandbox
TRUELAYER_CLIENT_ID=sandbox-yourapp-xxxxxx
TRUELAYER_CLIENT_SECRET=
TRUELAYER_REDIRECT_URI=http://localhost:3000/callback

# Proveedores (bancos) que se muestran en el diálogo de consentimiento.
# TrueLayer cubre cientos de bancos de UK y Europa; elige el tuyo en la consola.
#   sandbox -> Mock Bank:            uk-cs-mock
#   live (todos los de un país) ->   es-ob-all  ·  uk-ob-all  ·  fr-ob-all ...
#   live (banco concreto) ->         es-ob-bbva ·  es-ob-santander ·  es-ob-caixabank ...
# Consulta los IDs exactos en console.truelayer.com (Data API > Providers).
TRUELAYER_PROVIDERS=uk-cs-mock

# === Almacenamiento ===
# Por defecto: SQLite en <repo>/data/finmcp.db. Descomenta para cambiar la ruta.
# FINMCP_DB_PATH=/ruta/absoluta/a/openbanking-mcp/data/finmcp.db

# === Cifrado de tokens en reposo ===
# Clave Fernet. Si la dejas vacía, se genera una y se guarda en data/fernet.key (chmod 600).
# Generar una manualmente:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FINMCP_ENCRYPTION_KEY=

# Puerto del callback local del flujo OAuth (debe coincidir con la redirect URI)
FINMCP_CALLBACK_PORT=3000
