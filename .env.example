# === Proveedor Open Banking ===
FINMCP_PROVIDER=enablebanking

# === Enable Banking ===
# Registra una app en https://enablebanking.com (Control Panel):
#   - genera la clave en el navegador y DESCÁRGALA (solo se muestra una vez)
#   - redirect URL (exige HTTPS): https://localhost:3000/callback
#   - en la app, "Link accounts" para vincular tus cuentas (Restricted Production)
ENABLEBANKING_APP_ID=
# Clave privada: por defecto data/enablebanking_private.pem (descomenta para otra ruta)
# ENABLEBANKING_KEY_PATH=/ruta/absoluta/a/enablebanking_private.pem
# Nombre EXACTO del banco (lista con: finmcp institutions). Para CaixaBank: "CaixaBank".
ENABLEBANKING_ASPSP_NAME=
ENABLEBANKING_COUNTRY=ES
ENABLEBANKING_REDIRECT_URI=https://localhost:3000/callback

# === Almacenamiento ===
# Por defecto: SQLite en <repo>/data/finmcp.db. Descomenta para cambiar la ruta.
# FINMCP_DB_PATH=/ruta/absoluta/a/openbanking-mcp/data/finmcp.db

# === Cifrado de tokens/sesión en reposo ===
# Clave Fernet. Si la dejas vacía, se genera una y se guarda en data/fernet.key (chmod 600).
# Generar una manualmente:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FINMCP_ENCRYPTION_KEY=

# Puerto del callback local del flujo de autorización
FINMCP_CALLBACK_PORT=3000

# === Servidor MCP por HTTP (solo si usas `finmcp serve --http`, p.ej. ChatGPT) ===
# Token bearer exigido en cada petición. Déjalo vacío para stdio (Claude Desktop).
# FINMCP_HTTP_TOKEN=
